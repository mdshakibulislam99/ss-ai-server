"""
SearchService - Domain service for similar image search
"""

import io
import time
from typing import Any, Dict, List, Optional, Tuple

from ..interfaces.ai_provider import AIProvider
from ..interfaces.vector_store import VectorStore
from ..interfaces.cache import Cache
from ..interfaces.logger import Logger
from ..interfaces.repository import Repository
from ..value_objects.embedding_vector import EmbeddingVector
from ..entities.search_result import SearchResult
from ..entities.product import Product


# Supported image formats for validation
SUPPORTED_FORMATS = {"jpeg", "png", "webp"}
SUPPORTED_MIME_TYPES = {"image/jpeg", "image/png", "image/webp"}
MAX_IMAGE_DIMENSION = 4096


class SearchService:
    """
    Domain service for similar image search.
    
    Full search pipeline:
    1. Validate image bytes (format, size, safety)
    2. Generate embedding via AIProvider
    3. Search nearest neighbors via VectorStore
    4. Load product metadata from Repository
    5. Calculate confidence scores
    6. Sort and filter by threshold
    
    Depends only on interfaces - never on OpenCLIP or FAISS directly.
    """
    
    def __init__(
        self,
        ai_provider: AIProvider,
        vector_store: VectorStore,
        product_repository: Repository[Product],
        cache: Optional[Cache] = None,
        logger: Optional[Logger] = None,
    ) -> None:
        self._ai_provider = ai_provider
        self._vector_store = vector_store
        self._product_repository = product_repository
        self._cache = cache
        self._logger = logger
    
    async def search_similar(
        self,
        image_data: bytes,
        limit: int = 20,
        threshold: float = 0.7,
        cache_key: Optional[str] = None,
    ) -> Tuple[List[SearchResult], EmbeddingVector, float]:
        """
        Execute the full search pipeline.
        
        Args:
            image_data: Raw image bytes
            limit: Maximum number of results
            threshold: Minimum similarity threshold (0.0 to 1.0)
            cache_key: Optional cache key for caching results
            
        Returns:
            Tuple of (results, query_embedding, elapsed_ms)
            
        Raises:
            ValueError: If image validation fails
        """
        start = time.perf_counter()
        
        # Step 1: Validate image
        self._validate_image(image_data)
        
        # Step 2: Check cache
        if self._cache and cache_key:
            cached = await self._cache.get(cache_key)
            if cached is not None:
                elapsed = (time.perf_counter() - start) * 1000
                self._log_debug(f"Search cache hit for {cache_key}")
                return cached, elapsed
        
        # Step 3: Generate embedding via AIProvider
        try:
            query_embedding = self._ai_provider.generate_embedding(image_data)
        except Exception as e:
            self._log_error(f"AI provider embedding generation failed: {e}")
            raise RuntimeError(f"Failed to generate image embedding: {e}")
        
        # Step 4: Search nearest neighbors in VectorStore
        try:
            results = self._vector_store.search(
                query_embedding,
                limit=limit,
            )
        except Exception as e:
            self._log_error(f"Vector store search failed: {e}")
            raise RuntimeError(f"Failed to search similar images: {e}")
        
        # Step 5: Load product metadata and calculate confidence
        enriched_results = await self._enrich_results(results, threshold)
        
        # Step 6: Sort by similarity (descending)
        enriched_results.sort(key=lambda r: r.similarity_score, reverse=True)
        
        # Step 7: Cache results
        if self._cache and cache_key:
            await self._cache.set(cache_key, (enriched_results, query_embedding))
        
        elapsed = (time.perf_counter() - start) * 1000
        
        self._log_info(
            f"Search completed: {len(enriched_results)} results "
            f"in {elapsed:.0f}ms"
        )
        
        return enriched_results, query_embedding, elapsed
    
    def _validate_image(self, image_data: bytes) -> None:
        """
        Validate image bytes for format and integrity.
        
        Args:
            image_data: Raw image bytes
            
        Raises:
            ValueError: If validation fails
        """
        if not image_data or len(image_data) == 0:
            raise ValueError("Image data is empty")
        
        # Validate image format and integrity using Pillow
        try:
            from PIL import Image
            
            img = Image.open(io.BytesIO(image_data))
            
            # Check format
            fmt = img.format.lower() if img.format else ""
            if fmt not in SUPPORTED_FORMATS:
                raise ValueError(
                    f"Unsupported image format '{img.format}'. "
                    f"Supported formats: {', '.join(sorted(SUPPORTED_FORMATS))}"
                )
            
            # Force full load to catch corruption
            img.load()
            
            # Check dimensions
            width, height = img.size
            if width > MAX_IMAGE_DIMENSION or height > MAX_IMAGE_DIMENSION:
                raise ValueError(
                    f"Image dimensions ({width}x{height}) exceed maximum "
                    f"allowed ({MAX_IMAGE_DIMENSION}x{MAX_IMAGE_DIMENSION})"
                )
            
            # Verify mode is supported
            if img.mode not in ("RGB", "RGBA", "L"):
                img = img.convert("RGB")
            
        except ValueError:
            raise
        except Exception as e:
            raise ValueError(f"Invalid or corrupted image file: {e}")
    
    async def _enrich_results(
        self,
        results: List[SearchResult],
        threshold: float,
    ) -> List[SearchResult]:
        """
        Enrich search results with metadata and apply threshold filter.
        
        Args:
            results: Raw search results from vector store
            threshold: Minimum similarity threshold
            
        Returns:
            Filtered and enriched results
        """
        enriched: List[SearchResult] = []
        
        for result in results:
            # Apply threshold
            if result.similarity_score < threshold:
                continue
            
            # Load product metadata if available
            try:
                product = await self._product_repository.get_by_id(result.product_id)
                if product and product.metadata:
                    # Merge product metadata with existing
                    combined = dict(product.metadata)
                    combined.update(result.metadata or {})
                    combined["title"] = product.title
                    combined["image_urls"] = product.image_urls
                    result.metadata = combined
            except Exception:
                # Non-fatal: continue with existing metadata
                pass
            
            enriched.append(result)
        
        return enriched
    
    def _log_debug(self, message: str) -> None:
        if self._logger:
            self._logger.debug(message)
    
    def _log_info(self, message: str) -> None:
        if self._logger:
            self._logger.info(message)
    
    def _log_error(self, message: str) -> None:
        if self._logger:
            self._logger.error(message)
    
    def get_model_info(self) -> Optional[dict]:
        """Get vector store information"""
        try:
            stats = self._vector_store.get_stats()
            return stats.to_dict()
        except Exception:
            return None