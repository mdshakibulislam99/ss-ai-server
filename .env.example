# Application
APP_NAME=SS AI Server
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4
TIMEOUT=30

# Database
DATABASE_TYPE=postgresql
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ss_ai_server
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_PREFIX=ss_ai_cache

# Vector Store
VECTOR_STORE_TYPE=faiss
VECTOR_STORE_DIMENSIONS=512
VECTOR_STORE_METRIC=cosine
VECTOR_STORE_PATH=/data/vector_store

# AI Provider
AI_DEFAULT_PROVIDER=openclip
AI_DEFAULT_MODEL=ViT-B-32
AI_DEVICE=auto
AI_PRECISION=fp32
AI_CACHE_ENABLED=true
AI_CACHE_DIR=/models

# Security
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# API Keys
API_KEY_HEADER=X-API-Key
API_KEY_HASH_ALGORITHM=SHA256

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_WINDOW=60

# CORS
CORS_ENABLED=true
CORS_ORIGINS=["*"]

# Monitoring
MONITORING_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_ENABLED=true

# Logging
LOG_FORMAT=json
LOG_OUTPUTS=["console", "file"]
LOG_FILE_PATH=/logs/ss_ai_server.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=10

# Storage
STORAGE_TYPE=local
STORAGE_PATH=/data/storage
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Queue
QUEUE_TYPE=redis
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_DB=1
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_BACKOFF=2.0
QUEUE_JOB_TIMEOUT=3600

# Workers
WORKER_EMBEDDING_ENABLED=true
WORKER_EMBEDDING_CONCURRENCY=2
WORKER_BATCH_ENABLED=true
WORKER_BATCH_CONCURRENCY=1
WORKER_CLEANUP_ENABLED=true
WORKER_CLEANUP_SCHEDULE=0 3 * * *

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_STORAGE_TYPE=influxdb
ANALYTICS_RETENTION=90d

# Encryption
ENCRYPTION_AT_REST=true
ENCRYPTION_IN_TRANSIT=true
ENCRYPTION_ALGORITHM=AES-256-GCM